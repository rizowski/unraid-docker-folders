  var SIZE_MAP = { sm: '420px', md: '560px', lg: '760px', xl: '960px' };

  // ----- Helpers -----

  function clearChildren(el) {
    while (el.firstChild) el.removeChild(el.firstChild);
  }

  function styleObj(el, styles) {
    for (var k in styles) {
      if (Object.prototype.hasOwnProperty.call(styles, k)) {
        el.style[k] = styles[k];
      }
    }
  }

  function inputBaseStyles() {
    return {
      width: '100%',
      padding: '8px 12px',
