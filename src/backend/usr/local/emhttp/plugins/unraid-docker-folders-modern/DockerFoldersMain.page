  }

  function renderTextField(field) {
    var p = document.createElement('p');
    p.textContent = field.text || '';
    p.style.margin = '0';
    p.style.fontSize = '14px';
    p.style.lineHeight = '1.5';
    var variant = field.variant || 'default';
    if (variant === 'muted') p.style.opacity = '0.7';
    else if (variant === 'error') p.style.color = '#f44336';
    else if (variant === 'success') p.style.color = '#4caf50';
    return { root: p, refs: { text: p } };
  }

  function renderHeadingField(field) {
    var h = document.createElement('h3');
    h.textContent = field.text || '';
    styleObj(h, {
      margin: '0',
      fontSize: '16px',
      fontWeight: '600'
    });
    return { root: h, refs: { text: h } };
  }

  function renderInputField(field) {
    var wrap = document.createElement('div');
    if (field.label) wrap.appendChild(makeLabel(field.label));
    var input = document.createElement('input');
    input.type = field.inputType || 'text';
    input.value = field.value || '';
    if (field.placeholder) input.placeholder = field.placeholder;
    if (field.required) input.required = true;
    if (field.pattern) input.pattern = field.pattern;
    styleObj(input, inputBaseStyles());
    wrap.appendChild(input);
    if (field.suffix) wrap.appendChild(makeCaption(field.suffix));
    if (field.autofocus) setTimeout(function() { input.focus(); input.select && input.select(); }, 50);
    // Enter submits first primary action
    input.addEventListener('keydown', function(e) {
      if (e.key === 'Enter') {
        e.preventDefault();
        submitDefaultAction();
      }
    });
    input.addEventListener('input', refreshActionStates);
    return { root: wrap, refs: { input: input } };
  }

  function renderTextareaField(field) {
    var wrap = document.createElement('div');
    if (field.fillHeight) {
      wrap.className = 'dfm-wrap-fill';
      styleObj(wrap, { flex: '1', display: 'flex', flexDirection: 'column', minHeight: '0' });
    }
    if (field.label) wrap.appendChild(makeLabel(field.label));
    if (field.caption) {
      var cap = document.createElement('div');
