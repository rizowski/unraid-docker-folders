<script>
(function() {
  var frame = document.getElementById('docker-folders-frame');
  var token = (typeof csrf_token === 'string') ? csrf_token : '';

  // Read Unraid CSS variables from parent document so the iframe can match the theme
  var vars = [
    '--text-color', '--background-color', '--border-color',
    '--header-background', '--header-text-color',
    '--button-background', '--button-hover', '--button-text-color',
    '--input-background', '--input-border'
  ];
  var cs = getComputedStyle(document.documentElement);
  var theme = {};
  vars.forEach(function(v) {
    var val = cs.getPropertyValue(v).trim();
    if (val) theme[v] = val;
  });
  var themeParam = Object.keys(theme).length > 0
    ? '&theme=' + encodeURIComponent(JSON.stringify(theme))
    : '';

  frame.src = '/plugins/unraid-docker-folders-modern/assets/index.html?csrf_token=' + encodeURIComponent(token) + themeParam;

  // Parent-page modal state
  var modalData = null;
  var activeTab = 'compose';

  window.dfmSwitchTab = function(tab) {
    activeTab = tab;
    var composeContent = document.getElementById('dfm-content-compose');
    var envContent = document.getElementById('dfm-content-env');
    var tabCompose = document.getElementById('dfm-tab-compose');
    var tabEnv = document.getElementById('dfm-tab-env');

    if (tab === 'compose') {
      composeContent.style.display = 'flex';
      envContent.style.display = 'none';
      tabCompose.style.background = 'var(--header-background,#ff8c2f)';
      tabCompose.style.color = 'var(--header-text-color,#fff)';
      tabCompose.style.borderColor = 'transparent';
      tabEnv.style.background = 'color-mix(in srgb,var(--text-color,#f2f2f2) 6%,transparent)';
      tabEnv.style.color = 'var(--text-color,#f2f2f2)';
      tabEnv.style.borderColor = 'var(--border-color,#333)';
    } else {
      composeContent.style.display = 'none';
      envContent.style.display = 'flex';
      tabEnv.style.background = 'var(--header-background,#ff8c2f)';
      tabEnv.style.color = 'var(--header-text-color,#fff)';
      tabEnv.style.borderColor = 'transparent';
      tabCompose.style.background = 'color-mix(in srgb,var(--text-color,#f2f2f2) 6%,transparent)';
      tabCompose.style.color = 'var(--text-color,#f2f2f2)';
      tabCompose.style.borderColor = 'var(--border-color,#333)';
    }
  };

  function showModal(data) {
    modalData = data;
    activeTab = 'compose';

    var isCreate = data.kind === 'compose-create';
    document.getElementById('dfm-modal-title').textContent = data.title || 'Compose';
    document.getElementById('dfm-project-name').style.display = isCreate ? '' : 'none';
    document.getElementById('dfm-project-name').value = '';
    document.getElementById('dfm-compose-textarea').value = data.composeContent || '';
    document.getElementById('dfm-compose-textarea').readOnly = !!data.readOnly;
    document.getElementById('dfm-compose-path').textContent = data.composePath || '';
    document.getElementById('dfm-compose-path').style.display = isCreate ? 'none' : '';
    document.getElementById('dfm-env-textarea').value = data.envContent || '';
    document.getElementById('dfm-env-textarea').readOnly = !!data.readOnly;
    document.getElementById('dfm-env-path').value = data.envPath || '';
    document.getElementById('dfm-env-file-path').textContent = data.envFilePath || '';
    document.getElementById('dfm-save-status').textContent = '';

    // Show/hide save button based on readOnly
    document.getElementById('dfm-btn-save').style.display = data.readOnly ? 'none' : '';
    document.getElementById('dfm-btn-save').textContent = isCreate ? 'Create' : 'Save';
    document.getElementById('dfm-btn-cancel').textContent = data.readOnly ? 'Close' : 'Cancel';

    // Reset to compose tab
    dfmSwitchTab('compose');

    // Show overlay
    var overlay = document.getElementById('dfm-modal-overlay');
    overlay.style.display = 'flex';
  }

  window.dfmCloseModal = function() {
    document.getElementById('dfm-modal-overlay').style.display = 'none';
    modalData = null;
    // Tell iframe the modal closed
    frame.contentWindow.postMessage({ type: 'docker-folders-modal-action', action: 'close' }, '*');
  };

  window.dfmSaveModal = function() {
    if (!modalData) return;

    // Create mode
    if (modalData.kind === 'compose-create') {
      var projectName = document.getElementById('dfm-project-name').value.trim();
      if (!projectName) {
        var s = document.getElementById('dfm-save-status');
        s.style.color = '#f44336';
        s.textContent = 'Stack name is required';
        return;
      }
      frame.contentWindow.postMessage({
        type: 'docker-folders-modal-action',
        action: 'create',
        projectName: projectName,
        composeContent: document.getElementById('dfm-compose-textarea').value,
        envContent: document.getElementById('dfm-env-textarea').value
      }, '*');
      return;
    }

    // Edit mode
    var content, tab;
    if (activeTab === 'compose') {
      content = document.getElementById('dfm-compose-textarea').value;
      tab = 'compose';
    } else {
      content = document.getElementById('dfm-env-textarea').value;
      tab = 'env';
    }
    frame.contentWindow.postMessage({
      type: 'docker-folders-modal-action',
      action: 'save',
      tab: tab,
      content: content,
      projectName: modalData.projectName
    }, '*');
  };

  // Close modal on overlay click
  document.getElementById('dfm-modal-overlay').addEventListener('click', function(ev) {
    if (ev.target === this) dfmCloseModal();
  });

  // Close modal on Escape key
  document.addEventListener('keydown', function(ev) {
    if (ev.key === 'Escape' && document.getElementById('dfm-modal-overlay').style.display === 'flex') {
      dfmCloseModal();
    }
  });

  window.addEventListener('message', function(e) {
    if (e.data && e.data.type === 'docker-folders-resize') {
      frame.style.height = e.data.height + 'px';
    }
    // Modal open/close from iframe
    if (e.data && e.data.type === 'docker-folders-modal') {
      if (e.data.open && e.data.modal) {
        showModal(e.data.modal);
      } else if (!e.data.open) {
        document.getElementById('dfm-modal-overlay').style.display = 'none';
        modalData = null;
      }
    }
    // Save result from iframe
    if (e.data && e.data.type === 'docker-folders-modal-result') {
      var statusEl = document.getElementById('dfm-save-status');
      if (e.data.success) {
        statusEl.style.color = '#4caf50';
        statusEl.textContent = 'Saved';
        setTimeout(function() { statusEl.textContent = ''; }, 2000);
      } else {
        statusEl.style.color = '#f44336';
        statusEl.textContent = e.data.error || 'Failed to save';
      }
    }
  });
})();
</script>
<?php endif; ?>
