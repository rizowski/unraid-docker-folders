      <span id="dfm-save-status" style="font-size:13px;"></span>
      <div style="display:flex;gap:8px;">
        <button onclick="dfmCloseModal()" id="dfm-btn-cancel" style="padding:8px 20px;border:1px solid var(--border-color,#333);border-radius:4px;font-size:13px;font-weight:600;cursor:pointer;background:color-mix(in srgb,var(--text-color,#f2f2f2) 6%,transparent);color:var(--text-color,#f2f2f2);">Close</button>
        <button onclick="dfmSaveModal()" id="dfm-btn-save" style="display:none;padding:8px 20px;border:none;border-radius:4px;font-size:13px;font-weight:600;cursor:pointer;background:var(--header-background,#ff8c2f);color:var(--header-text-color,#fff);">Save</button>
