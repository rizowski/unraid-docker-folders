        <textarea id="dfm-compose-textarea" style="flex:1;min-height:200px;padding:12px;font-family:ui-monospace,SFMono-Regular,Menlo,Monaco,Consolas,monospace;font-size:14px;background:color-mix(in srgb,var(--background-color,#1a1a1a),var(--text-color,#f2f2f2) 8%);color:var(--text-color,#f2f2f2);border:1px solid var(--border-color,#333);border-radius:4px;resize:vertical;box-sizing:border-box;width:100%;" spellcheck="false"></textarea>
