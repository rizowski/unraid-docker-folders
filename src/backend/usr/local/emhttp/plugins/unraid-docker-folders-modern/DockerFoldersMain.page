</div>
<?php else: ?>
<iframe id="docker-folders-frame"
        style="width:100%;min-height:600px;border:none;"
        scrolling="no"
        allowfullscreen></iframe>
<script>
(function() {
  var frame = document.getElementById('docker-folders-frame');
  var token = (typeof csrf_token === 'string') ? csrf_token : '';

  // Read Unraid CSS variables from parent document so the iframe can match the theme
  var vars = [
    '--text-color', '--background-color', '--border-color',
    '--header-background', '--header-text-color',
    '--button-background', '--button-hover', '--button-text-color',
    '--input-background', '--input-border'
  ];
  var cs = getComputedStyle(document.documentElement);
  var theme = {};
  vars.forEach(function(v) {
    var val = cs.getPropertyValue(v).trim();
    if (val) theme[v] = val;
  });
  var themeParam = Object.keys(theme).length > 0
    ? '&theme=' + encodeURIComponent(JSON.stringify(theme))
    : '';

  frame.src = '/plugins/unraid-docker-folders-modern/assets/index.html?csrf_token=' + encodeURIComponent(token) + themeParam;
  window.addEventListener('message', function(e) {
    if (e.data && e.data.type === 'docker-folders-resize') {
      frame.style.height = e.data.height + 'px';
    }
    if (e.data && e.data.type === 'docker-folders-modal') {
      if (e.data.open) {
        frame.style.position = 'relative';
        frame.style.zIndex = '999';
        frame._scrollLock = function(ev) { ev.preventDefault(); };
        frame._keyLock = function(ev) {
          if ([32, 33, 34, 35, 36, 38, 40].indexOf(ev.keyCode) !== -1) ev.preventDefault();
        };
        window.addEventListener('wheel', frame._scrollLock, { passive: false });
        window.addEventListener('touchmove', frame._scrollLock, { passive: false });
        window.addEventListener('keydown', frame._keyLock);
      } else {
        frame.style.position = '';
        frame.style.zIndex = '';
        if (frame._scrollLock) {
          window.removeEventListener('wheel', frame._scrollLock);
          window.removeEventListener('touchmove', frame._scrollLock);
          window.removeEventListener('keydown', frame._keyLock);
        }
      }
    }
  });
})();
</script>
<?php endif; ?>
