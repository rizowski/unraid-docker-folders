<?php
require_once '/usr/local/emhttp/plugins/unraid-docker-folders-modern/include/config.php';
require_once '/usr/local/emhttp/plugins/unraid-docker-folders-modern/classes/Database.php';

$db = Database::getInstance();
$row = $db->fetchOne('SELECT value FROM settings WHERE key = ?', ['replace_docker_section']);
$replaceDockersSection = ($row && $row['value'] === '1');

if (!$replaceDockersSection) return;

// Visibility of the legacy (native) container list and action buttons.
// Both hidden by default; opt back in via the plugin settings page.
$row = $db->fetchOne('SELECT value FROM settings WHERE key = ?', ['show_legacy_containers']);
$showLegacyContainers = ($row && $row['value'] === '1');
$row = $db->fetchOne('SELECT value FROM settings WHERE key = ?', ['show_legacy_buttons']);
$showLegacyButtons = ($row && $row['value'] === '1');
?>

<?php if (!$showLegacyButtons): ?>
<style>
/* Hide the native Docker page action button row (Add Container, Start All,
   Stop All, Check for Updates, ...). CSS with !important wins even when
   dockerMan's own scripts rewrite the buttons' style attributes, and it
   applies regardless of when the buttons are inserted into the DOM. */
.js-actions { display: none !important; }
</style>
<?php endif; ?>

<script>
(function() {
  var SHOW_LEGACY_CONTAINERS = <?= $showLegacyContainers ? 'true' : 'false' ?>;
  var SHOW_LEGACY_BUTTONS = <?= $showLegacyButtons ? 'true' : 'false' ?>;
  function hideNativeDockerSection() {
    // Hide the "Docker Containers" title bar
    document.querySelectorAll('div.title').forEach(function(el) {
      if (el.textContent && /Docker Containers/i.test(el.textContent)) {
        el.style.display = 'none';
      }
    });


    // Hide the view mode toggle
    document.querySelectorAll('.ToggleViewMode').forEach(function(el) {
      el.style.display = 'none';
    });

    // Hide the container list itself
    var containerSection = null;
    var selectors = [
      '#docker_list',
      '#docker_containers',
      'table.docker_readmore',
      '#dockerContainerTable',
    ];
    for (var i = 0; i < selectors.length; i++) {
      containerSection = document.querySelector(selectors[i]);
      if (containerSection) break;
    }

    if (!containerSection) {
      var ctName = document.querySelector('.ct-name');
      if (ctName) {
        containerSection = ctName.closest('table') || ctName.closest('div');
      }
    }

    if (containerSection) {
      // If we found a tbody/thead, walk up to the parent table first
      var target = containerSection;
      if (target.tagName === 'TBODY' || target.tagName === 'THEAD') {
        target = target.closest('table') || target;
      }

      // Walk up to find the outermost single-child wrapper
      while (target.parentElement) {
        var parent = target.parentElement;
        if (parent === document.body || parent.id === 'content_all' || parent.id === 'tab1' ||
            parent.classList.contains('content') || parent.tagName === 'FORM') break;
        var siblings = Array.from(parent.childNodes).filter(function(n) {
          return n.nodeType === 1 || (n.nodeType === 3 && n.textContent.trim());
        });
        if (siblings.length === 1) {
          target = parent;
        } else {
          break;
        }
      }

      if (SHOW_LEGACY_CONTAINERS) {
        // Wrap native section in a collapsed accordion
        var accordion = document.createElement('details');
        accordion.className = 'native-docker-accordion';
        accordion.style.cssText = 'margin-top:12px;width:100%;';

        var summary = document.createElement('summary');
        summary.style.cssText = 'cursor:pointer;padding:8px 12px;font-size:13px;user-select:none;';
        summary.textContent = 'Native Docker Containers';
        accordion.appendChild(summary);

        target.parentElement.insertBefore(accordion, target);
        accordion.appendChild(target);
      } else {
        // Legacy container list hidden entirely (default)
        target.style.display = 'none';
      }
    }

    return !!containerSection;
  }

  // Labels of the native Docker page action buttons (dockerMan renders them
  // in a div.js-actions, hidden via CSS above). This JS pass is a fallback
  // for markups where that class is absent, hidden unless the
  // "show legacy buttons" setting is enabled.
  var NATIVE_BUTTON_LABELS = [
    'add container',
    'start all',
    'stop all',
    'pause all',
    'resume all',
    'check for updates',
    'update all',
    'apply update',
    'container size',
  ];

  function hideNativeButtons() {
    if (SHOW_LEGACY_BUTTONS) return true;

    var found = false;
    var candidates = document.querySelectorAll('input[type="button"], button');
    candidates.forEach(function(el) {
      // Never touch the plugin's own UI or anything inside the native accordion
      // (the accordion already scopes its own visibility)
      if (el.closest('[id*="docker-folders"]') || el.closest('.native-docker-accordion')) return;

      var label = (el.value || el.textContent || '').trim().toLowerCase();
      if (NATIVE_BUTTON_LABELS.indexOf(label) !== -1) {
        // Prefer hiding the whole action row; dockerMan rewrites the buttons'
        // own style attributes, so per-element hiding must use !important.
        var row = el.closest('.js-actions');
        (row || el).style.setProperty('display', 'none', 'important');
        found = true;
      }
    });

    return found;
  }

  var attempts = 0;
  var sectionDone = false;
  var buttonsDone = false;
  function tryHide() {
    sectionDone = hideNativeDockerSection() || sectionDone;
    buttonsDone = hideNativeButtons() || buttonsDone;
    if ((!sectionDone || !buttonsDone) && attempts < 20) {
      attempts++;
      setTimeout(tryHide, 250);
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', tryHide);
  } else {
    setTimeout(tryHide, 100);
  }
})();
</script>
